datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
// Define the Client entity
model Client {
  id      Int      @id @default(autoincrement())
  nom                 String
  prenom              String
  email               String
  telephone           Int
  mdps                String
  date_de_naissance   DateTime?
  sex                 String?
  date_d_inscription  DateTime?

  //posts   Post[]
  clientVip ClientVip?
}

model ClientVip {
  id                 Int     @id @default(autoincrement())
  nom                String
  prenom             String
  email              String
  telephone          Int
  mdps               String
  dateDeNaissance    DateTime?
  sex                String?
  dateDInscription   DateTime?

  client             Client  @relation(fields: [clientId], references: [id])
  clientId           Int     @unique
}

