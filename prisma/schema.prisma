datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL") // uses connection pooling
  
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String
  posts Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String
  published Boolean
  user      User    @relation(fields: [userId], references: [id])
  userId    Int
}

model Client {
  id                Int         @id @default(autoincrement())
  nom               String
  prenom            String
  email             String
  telephone         Int
  mdps              String
  date_naissance    DateTime?
  sex               String?
  date_dinscription DateTime?
  clientVips        ClientVip[] @relation("ClientToClientVIP")
}

model ClientVip {
  id                Int       @id @default(autoincrement())
  nom               String?
  prenom            String?
  email             String?
  telephone         Int?
  mdps              String?
  date_naissance    DateTime?
  sex               String?
  date_dinscription DateTime?
  client            Client    @relation(name: "ClientToClientVIP", fields: [clientId], references: [id])
  clientId          Int

  @@map("Client vip")
}

model Proprietaire {
  id                Int         @id @default(autoincrement())
  nom               String
  prenom            String
  email             String
  ville             String?
  telephone         Float
  mdps              String
  date_naissance    DateTime?
  sex               String?
  date_dinscription DateTime?
  proprietaireVip    ProprietaireVip[] @relation("ProprietaireToProprietaireVIP")
  biens             Biens[]      @relation(name: "ProprietaireToBiens")
}


model ProprietaireVip {
  id                Int         @id @default(autoincrement())
  nom               String
  prenom            String
  email             String
  ville             String?
  telephone         Float
  mdps              String
  date_naissance    DateTime?
  sex               String?
  date_dinscription DateTime?
  proprietaire       Proprietaire @relation(name: "ProprietaireToProprietaireVIP", fields: [proprietaireId], references: [id])
  proprietaireId     Int

  @@map("ProprietaireVip")
}

model Biens {
  id      Int      @id @default(autoincrement())
  description   String?
  type_bien     String?
  adresse       String?
  ville         String?
  code_postal   String[]
  prix_estime   Float?
  etat          String?
  proprietaire  Proprietaire @relation(name: "ProprietaireToBiens" ,fields: [id_proprietaire], references: [id])
  id_proprietaire Int
}


