datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL") // uses connection pooling
  
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  name  String
  posts Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String
  published Boolean
  user      User    @relation(fields: [userId], references: [id])
  userId    Int
}

model Client {
  id                Int         @id @default(autoincrement())
  nom               String
  prenom            String
  email             String
  telephone         String
  mdps              String
  date_naissance    String?  // update to DateTime type
  sex               String?
  date_dinscription String?
  clientVips        ClientVip[] @relation("ClientToClientVIP")
  proprietaires     Proprietaire[]
}

model ClientVip {
  id                Int       @id @default(autoincrement())
  nom               String?
  prenom            String?
  email             String?
  telephone         String?
  mdps              String?
  date_naissance    String?
  sex               String?
  date_dinscription String?
  client            Client    @relation(name: "ClientToClientVIP", fields: [clientId], references: [id])
  clientId          Int

  @@map("Client vip")
}

model Proprietaire {
  id                Int         @id @default(autoincrement())
  nom               String
  prenom            String
  email             String
  ville             String?
  telephone         String
  mdps              String
  date_naissance    String?
  sex               String?
  date_dinscription String?
  proprietaireVip   ProprietaireVip[] @relation("ProprietaireToProprietaireVIP")
  client            Client?    @relation(fields: [clientId], references: [id])
  clientId          Int?
  biens             Biens[]      @relation(name: "ProprietaireToBiens")
}

model ProprietaireVip {
  id                Int         @id @default(autoincrement())
  nom               String
  prenom            String
  email             String
  ville             String?
  telephone         String
  mdps              String
  date_naissance    String?
  sex               String?
  date_dinscription String?
  proprietaire       Proprietaire @relation(name: "ProprietaireToProprietaireVIP", fields: [proprietaireId], references: [id])
  proprietaireId     Int

  @@map("ProprietaireVip")
}

model Biens {
  id              Int          @id @default(autoincrement())
  description     String?
  type_bien       String?
  adresse         String
  ville           String?
  code_postal     String[]
  prix_estime     String?
  etat            String?
  proprietaire    Proprietaire @relation(name: "ProprietaireToBiens", fields: [id_proprietaire], references: [id])
  id_proprietaire Int
}
